<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      Title="{Loc 'computer-iff-ebent-console-window-title'}"
                      MinSize="220 120">
    <BoxContainer Orientation="Vertical" HorizontalExpand="True">
        <GridContainer Margin="4 0 0 0" Columns="2">
            <Label Name="StealthLabel" Text="{Loc 'computer-iff-ebent-console-label'}" HorizontalExpand="True" StyleClasses="highlight" />
            <Button Name="StealthButton" Text="{Loc 'computer-iff-ebent-console-activate'}" MinWidth="140" />
        </GridContainer>
        <BoxContainer Orientation="Vertical" Margin="4 4 0 0">
            <Label Name="StealthTimerLabel" HorizontalExpand="True" />
            <Label Name="CooldownTimerLabel" HorizontalExpand="True" />
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
